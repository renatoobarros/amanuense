[Unit]
Description=Whisper Dictation Daemon
Documentation=https://github.com/renatoobarros/amanuense
# Aguarda a sessão gráfica e o PipeWire estarem prontos
After=graphical-session.target pipewire.service pipewire-pulse.service
Requires=graphical-session.target

[Service]
Type=simple
ExecStart=%h/.local/bin/amanuense daemon
Restart=on-failure
RestartSec=5

# Logging: apenas warnings e erros por padrão.
# Para diagnóstico, altere para: RUST_LOG=whisper_dictate=info
Environment=RUST_LOG=warn

# Segurança: restrições de sandbox desnecessárias para uso pessoal,
# mas boas práticas de serviço de usuário:
# Impede que o processo eleve privilégios
NoNewPrivileges=true

[Install]
WantedBy=graphical-session.target
